# ─── NeuralTrace Environment Configuration ───
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Server ───
PORT=3000
BASE_URL=http://localhost:3000
ADMIN_PASSWORD=change-this-password

# ─── Mode ───
# "cloud" = multi-user with auth, billing, proxy
# "selfhosted" = single-user, direct API keys
NEURALTRACE_MODE=selfhosted

# ─── Embeddings (required for semantic search) ───
# Any OpenAI-compatible embedding endpoint. Examples:
#   Ollama:    http://localhost:11434/v1    (free, local, recommended)
#   OpenAI:    https://api.openai.com/v1
#   LocalAI:   http://localhost:8080/v1
#   LM Studio: http://localhost:1234/v1
# If omitted, search uses keyword matching only.
EMBEDDING_PROVIDER_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_API_KEY=              # Optional — Ollama doesn't need one
# EMBEDDING_DIMENSIONS=           # Optional — uses model default

# ─── Legacy (still works) ───
# If EMBEDDING_PROVIDER_URL is not set but OPENAI_API_KEY is,
# NeuralTrace auto-configures OpenAI as the embedding provider.
# OPENAI_API_KEY=your-openai-api-key-here

# ─── Auth (cloud mode only) ───
JWT_SECRET=change-this-to-a-random-string

# SMTP for magic link login (cloud mode only)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=you@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com

# ─── AI Proxy (cloud mode only) ───
# Proxies LLM requests for users without their own API key
# OPENROUTER_API_KEY=your-openrouter-key

# ─── Billing (cloud mode only) ───
# PADDLE_API_KEY=your-paddle-api-key
# PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
# PADDLE_CLIENT_TOKEN=your-paddle-client-token
# PADDLE_PRICE_ID=your-paddle-price-id
# PADDLE_ENVIRONMENT=sandbox

# ─── Consolidation (optional) ───
# Merges duplicate/similar traces automatically
# Requires OPENROUTER_API_KEY — skipped automatically if not set
# CONSOLIDATION_ENABLED=true
# CONSOLIDATION_MODEL=qwen/qwen3.5-flash-02-23
# CONSOLIDATION_INTERVAL_MS=1800000
# CONSOLIDATION_DRY_RUN=false
